# 私有化部署 .env 模板。客户需复制为 .env 并按需修改,**严禁**提交到版本库。
# 见 .gitignore:.env 已被忽略,只保留本示例。

ENVIRONMENT=dev

# ---- Postgres ----
DATABASE_URL=postgresql+psycopg://freehire:freehire@postgres:5432/freehire

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- 运维诊断端点 ----
# dev 下默认允许 /api/healthz?detail=1 与 /api/metrics 方便排错。
# prod/staging 默认隐藏;只有在反向代理/防火墙已限制内网访问后才建议打开。
EXPOSE_OPERATIONAL_DIAGNOSTICS=false

# ---- 对象存储 ----
# M0 默认本地文件系统;客户需要分布式/S3 兼容时,把 STORAGE_BACKEND 切换为
# s3 / seaweedfs / garage 等(M1 起逐步实现),业务代码不变。
STORAGE_BACKEND=local
STORAGE_ROOT=/var/lib/free-hire/objects

# ---- 鉴权 ----
# **生产部署必须改成 32+ 字符随机串**(例 `openssl rand -hex 32`)。
# dev 环境用默认值会被记录 warning,prod 环境拒绝启动。
JWT_SECRET=dev-only-please-change-in-prod-32+chars
JWT_EXPIRE_MINUTES=480

# ---- 首次启动管理员引导 ----
# 仅当用户表为空且两者都已设置时,启动时创建一个默认 admin。
# 创建后建议清空这两项以避免日志泄漏。
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin123456

# ---- License ----
# 容器化部署强烈推荐设置:容器内 /etc/machine-id 是 ephemeral 的,
# 不固定指纹会导致重建容器后 .lic 失效。
# 建议: openssl rand -hex 16 | xargs -I{} echo "MACHINE_FINGERPRINT_OVERRIDE={}"
MACHINE_FINGERPRINT_OVERRIDE=

# ---- 加密 Key (用于 DB 中存储 LLM API key 等敏感字段) ----
# 生产建议显式设置(`openssl rand -hex 32`); 留空则从 JWT_SECRET 派生(JWT 改动后历史加密无法解密)
LLM_KEY_ENCRYPTION_KEY=

# ---- LLM Provider 默认 (.env 兜底, DB 中已配则忽略) ----
# 推荐:首次部署写一份 key 到 .env, 启动后会自动 seed 为 DB 中第一条 active provider
# 之后管理员通过 UI(系统 → LLM 配置)增删改, 不需要再动 .env
# 留空 LLM_API_KEY 走 mock 模式 (demo 用,不依赖外部 API)。
# LLM_DEFAULT_MODEL 直接写 LiteLLM 标识符,如 openai/gpt-4o-mini、deepseek/deepseek-chat、azure/<deployment>
LLM_BASE_URL=
LLM_API_KEY=
LLM_DEFAULT_MODEL=openai/gpt-4o-mini

# ---- 邮箱后台同步 ----
# 每隔多少秒轮询一次所有启用的邮箱账户。设 0 禁用后台同步, 仅支持 UI 手动触发。
# 推荐 300(5 分钟); 邮箱多 / 简历重要时可调到 60。
EMAIL_SYNC_INTERVAL_SECONDS=300

# ---- 分布式锁 (multi-worker 必备) ----
# 单账户锁 TTL(秒): 覆盖一次 sync_account 的最坏耗时
# UI 手动 POST /sync 与后台 loop 共用此锁, 拿不到锁返回 409 / 跳过
EMAIL_SYNC_LOCK_TTL_SECONDS=600
# 全局 loop 锁 TTL(秒): 0 = 自动按 interval*2 计算
EMAIL_SYNC_LOOP_LOCK_TTL_SECONDS=0

# ---- Celery 异步队列 (M3-A2) ----
# 简历解析等耗时任务从 web request 转给 worker 容器。
# broker / result backend 留空时,默认派生 redis_url 的 /1 与 /2,
# 与 email_sync 锁占用的 /0 隔离。
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# worker 并发(单容器内进程数)。租户多 / 简历量大时调高,1 适合 demo。
CELERY_WORKER_CONCURRENCY=1
# 任务硬超时(秒):pdfplumber 卡死兜底用 SIGKILL。
CELERY_TASK_TIME_LIMIT=300
# 软超时(秒):提前抛 SoftTimeLimitExceeded,任务有机会标记 failed。
CELERY_TASK_SOFT_TIME_LIMIT=240
# 测试 / 本地无 worker 容器时设为 true,task 同步执行,不走 broker。
CELERY_TASK_ALWAYS_EAGER=false

# ---- CORS (本地开发) ----
# 生产私有化部署建议配置为同域反代,可置空
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# ---- 候选人邀请链接的公网根 URL (M4 远程面试) ----
# 邀请邮件 / HR 完成通知里的链接以此为前缀拼,例如:
#   PUBLIC_BASE_URL=https://hire.your-company.com
#   邀请链接将变为 https://hire.your-company.com/i/<token>
# 留空时取 CORS_ORIGINS 第一项,适合本地 demo。生产部署务必显式配置 — 否则
# 候选人收到的邮件里会是 http://localhost,无法点击。
PUBLIC_BASE_URL=

# ---- 语音面试 STT / TTS (M6) ----
# 默认 mock(出厂体验,demo / CI 不依赖外网)。切换 backend 后下面对应的
# *_API_BASE / *_API_KEY 必填,缺一直接报错(不会静默降级 mock)。
#
# 可选 backend:
#   mock                 出厂默认,无外部依赖
#   openai_compatible    OpenAI 兼容协议,可对接:
#                        - OpenAI 公网:        https://api.openai.com/v1
#                        - 阿里云 dashscope: https://dashscope.aliyuncs.com/compatible-mode/v1
#                        - 字节火山引擎 ARK: https://ark.cn-beijing.volces.com/api/v3
#                        - 自建 whisper.cpp / vLLM: http://内网:port/v1
STT_BACKEND=mock
STT_API_BASE=
STT_API_KEY=
# OpenAI: whisper-1
# 阿里 dashscope: paraformer-v2 / qwen-audio-asr
# 自建: 取决于服务端 model 名
STT_MODEL=whisper-1
# 中文岗 zh,英文岗 en — 会传给 STT 提升识别准确率
STT_LANGUAGE=zh

TTS_BACKEND=mock
TTS_API_BASE=
TTS_API_KEY=
# OpenAI: tts-1 / tts-1-hd
# 阿里 dashscope: cosyvoice-v1
TTS_MODEL=tts-1
# OpenAI 音色: alloy / echo / fable / onyx / nova / shimmer
# 阿里 cosyvoice: longxiaochun / longxiaobai / longwan 等
TTS_VOICE=alloy
# 浏览器 <audio> 兼容: mp3 / opus / aac / flac / wav
TTS_FORMAT=mp3
